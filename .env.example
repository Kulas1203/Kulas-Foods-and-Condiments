# ─────────────────────────────────────────────
# Kulas Foods and Condiments — Environment Config
# Copy to `.env` and fill in real values.
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL)
DATABASE_URL="postgresql://kulas:kulas@localhost:5432/kulas?schema=public"

# NextAuth / JWT
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"
JWT_SECRET="replace-with-a-long-random-string"

# Stripe (payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Kulas Foods <hello@kulasfoods.com>"

# AI recipe recommendations. Optional — falls back to a local recommender
# over the existing recipe catalog when neither key is set.
# Prefer GEMINI_API_KEY: Google's free tier (no credit card) via
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Or use Claude (paid):
ANTHROPIC_API_KEY="sk-ant-..."

# Media uploads (choose one)
# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# UploadThing
UPLOADTHING_TOKEN=""

# Seed admin (used by prisma/seed.ts)
ADMIN_EMAIL="admin@kulasfoods.com"
ADMIN_PASSWORD="ChangeMe123!"
